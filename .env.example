OPENAI_CHAT_MODEL=gpt-4o-mini

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

LLM_PROVIDER=openai
TEST_MODE=false
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=220
LLM_TOP_P=0.9
RAG_CHUNK_SIZE=850
RAG_CHUNK_OVERLAP=120
RAG_INITIAL_RETRIEVAL_K=10
RAG_FINAL_RETRIEVAL_K=4
RAG_ENABLE_RERANK=true
RAG_USE_CROSS_ENCODER=false
RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_MAX_CONTEXT_CHARS=8000
RAG_SOURCE_DISPLAY_K=5
RAG_ENABLE_GENERAL_FALLBACK=true
RAG_MIN_SIMILARITY_SCORE=0.65
RAG_MIN_RELEVANT_CHUNKS=2
RAG_BRIEF_QUERY_MAX_WORDS=8
RAG_BRIEF_NUM_PREDICT=80
RAG_NORMAL_NUM_PREDICT=220
RAG_SKIP_RERANK_FOR_BRIEF_QUERIES=true
RAG_CHAT_HISTORY_TURNS=4
RAG_DEFAULT_ANSWER_STYLE=student-friendly, 1-3 paragraphs
